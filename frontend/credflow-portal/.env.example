# CredFlow Finance User Portal — frontend environment variables
# Copy to .env.local or .env (Vite loads both)
#
#   cp .env.example .env
#
# Local development: defaults below work out of the box if backend runs on default ports.
# Production: set these to your deployed API URLs.

VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_CRM_SERVICE_URL=http://127.0.0.1:9001
VITE_DOC_PROCESSOR_URL=http://127.0.0.1:8005
