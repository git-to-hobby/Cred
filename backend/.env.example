# =============================================================================
# Backend Environment Variables — copy this file to .env and fill in your values
#
#   cp .env.example .env
#
# Also copy/sync to:
#   - master_agent/.env
#   - agents/sales_agent/.env
#
# NEVER commit .env to git (real secrets stay local only).
# =============================================================================


# -----------------------------------------------------------------------------
# Google Gemini (REQUIRED for AI chat, sales agent, document processing)
# Get your key: https://aistudio.google.com/apikey
# Typical format starts with "AIza..."
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=your_gemini_api_key_here


# -----------------------------------------------------------------------------
# PostgreSQL (REQUIRED)
# Create database first: createdb loan_chatbot_db
# Then run: cd db && python setup_postgres_db.py
# Note: setup_postgres_db.py has its own DATABASE_CONFIG — keep password in sync.
# -----------------------------------------------------------------------------
DB_NAME=loan_chatbot_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432


# -----------------------------------------------------------------------------
# MongoDB (REQUIRED for chat history & loan lifecycle archives)
# Local default — change if using MongoDB Atlas or remote server
# Example Atlas: mongodb+srv://user:pass@cluster.mongodb.net/
# -----------------------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=loan_archives


# -----------------------------------------------------------------------------
# Tesseract OCR (REQUIRED for document upload / KYC processing)
# Pick the path for your OS (comment out the one you don't use)
# -----------------------------------------------------------------------------

# macOS (Homebrew)
TESSERACT_CMD=/opt/homebrew/bin/tesseract

# Windows
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe

# Linux (Ubuntu/Debian)
# TESSERACT_CMD=/usr/bin/tesseract


# =============================================================================
# OPTIONAL — not read from .env today (hardcoded in code), listed for reference
# Uncomment only if you wire these into the codebase later / for deployment notes
# =============================================================================

# GEMINI_MODEL=gemini-2.5-flash
# CRM_SERVICE_URL=http://127.0.0.1:9001
# CREDIT_BUREAU_URL=http://127.0.0.1:9002/credit_score
# SALES_AGENT_URL=http://127.0.0.1:8001/sales
# VERIFICATION_AGENT_URL=http://127.0.0.1:8002/verify
# VERIFICATION_STATEMENT_URL=http://127.0.0.1:8002/analyze-statement
# UNDERWRITING_AGENT_URL=http://127.0.0.1:8003/underwrite
# SANCTION_AGENT_URL=http://127.0.0.1:8004/sanction
# DOC_PROCESSOR_URL=http://127.0.0.1:8005/verify_salary


# -----------------------------------------------------------------------------
# SMTP Email Configuration (REQUIRED for customer registration emails)
# For Gmail, use App Password: https://support.google.com/accounts/answer/185833
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@credflow.com


# -----------------------------------------------------------------------------
# Platform Admin (optional env fallback) — set a random ID + strong password locally
# Run: cd backend/db && python seed_bankers.py --rotate
# Credentials saved to backend/db/.banker_credentials.local.json (never commit)
# -----------------------------------------------------------------------------
ADMIN_BANKER_ID=BK_set_your_random_id_in_env
ADMIN_PASSWORD=use_a_long_random_password_min_12_chars
ADMIN_NAME=CredFlow Platform Admin
ADMIN_ROLE=Platform Admin
# ADMIN_LOGIN_MAX_ATTEMPTS=5
# ADMIN_LOGIN_LOCKOUT_SEC=900
# PLATFORM_ADMIN_EMAIL=your_email@gmail.com
# Optional: separate signing secret (defaults to GOOGLE_API_KEY if unset)
# ADMIN_SECRET=long_random_secret_string
# ADMIN_TOKEN_TTL_SEC=86400
