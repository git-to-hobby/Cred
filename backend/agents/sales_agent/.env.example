# Sales Agent loads .env from THIS folder (agents/sales_agent/.env).
# Keep it in sync with backend/.env — especially GOOGLE_API_KEY and DB_* values.
#
#   cp ../../.env.example ../../.env   # if you haven't created .env yet
#   cp ../../.env .env                 # sync from main backend/.env

GOOGLE_API_KEY=your_gemini_api_key_here
DB_NAME=loan_chatbot_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432
